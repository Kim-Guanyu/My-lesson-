<view class="register-board">
  <van-field label="登录账号" model:value="{{username}}" custom-class="field" border="{{false}}" clearable placeholder="4~20位字母或数字"/>
  <van-field label="登录密码" model:value="{{password}}" custom-class="field" type="password" border="{{false}}" clearable placeholder="4~20位字母或数字"/>
  <van-field label="确认密码" model:value="{{rePassword}}" custom-class="field" type="password" border="{{false}}" clearable placeholder="再次输入密码"/>
  <van-field label="真实姓名" model:value="{{realname}}" custom-class="field" border="{{false}}" clearable placeholder="2~6个汉字"/>
  <van-field label="手机号码" model:value="{{phone}}" custom-class="field" border="{{false}}" clearable placeholder="11位手机号"/>
  <van-field label="身份证号" model:value="{{idcard}}" custom-class="field" border="{{false}}" clearable placeholder="18位身份证号"/>
  <van-field label="电子邮箱" model:value="{{email}}" custom-class="field" border="{{false}}" clearable placeholder="邮箱"/>
  <van-button custom-class="reg-btn" type="info" block bind:tap="register">注册</van-button>
  <van-row custom-class="link">
    <van-col span="8" bind:tap="toLoginByAccount">账号登录</van-col>
    <van-col span="8" bind:tap="toLoginByPhone">手机登录</van-col>
    <van-col span="8" bind:tap="toIndex">返回首页</van-col>
  </van-row>
</view>
