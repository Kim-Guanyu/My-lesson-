<view class="page">
  <van-radio-group value="{{gender}}" bind:change="onGenderChange">
    <van-cell-group>
      <van-cell title="男" clickable data-value="1" bind:click="onGenderTap">
        <van-radio name="1" />
      </van-cell>
      <van-cell title="女" clickable data-value="0" bind:click="onGenderTap">
        <van-radio name="0" />
      </van-cell>
      <van-cell title="保密" clickable data-value="2" bind:click="onGenderTap">
        <van-radio name="2" />
      </van-cell>
    </van-cell-group>
  </van-radio-group>
  <van-button class="submit-btn" type="primary" block loading="{{saving}}" bind:tap="submit">保存</van-button>
</view>
