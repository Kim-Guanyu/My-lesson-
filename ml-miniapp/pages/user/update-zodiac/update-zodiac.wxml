<view class="page">
  <van-field
    label="星座"
    value="{{zodiac}}"
    readonly
    is-link
    placeholder="请选择星座"
    bind:tap="openPicker"
  />
  <van-button class="submit-btn" type="primary" block loading="{{saving}}" bind:tap="submit">保存</van-button>
</view>

<van-popup show="{{pickerVisible}}" position="bottom" bind:close="closePicker">
  <van-picker columns="{{zodiacOptions}}" bind:confirm="onPickerConfirm" bind:cancel="closePicker" />
</van-popup>
